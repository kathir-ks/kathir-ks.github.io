# ── Cloudflare Worker secrets ──
# Set these via `wrangler secret put NAME` inside each worker dir.
# This file is for documentation only; it is NOT loaded by anything.

# LLM provider key (pick one matching wrangler.toml's LLM_PROVIDER):
GEMINI_KEY=
OPENAI_KEY=
ANTHROPIC_KEY=

# GitHub PAT (public-repo read-only is sufficient — `public_repo` scope).
GITHUB_TOKEN=

# Random string; gates POST /refresh on the API worker.
ADMIN_TOKEN=

# ── GitHub Actions secrets (set in repo Settings → Secrets → Actions) ──
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
